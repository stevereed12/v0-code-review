# ── White80 routine environment ──
# Required
ANTHROPIC_API_KEY=sk-ant-...
RESEND_API_KEY=re_...
RUN_SECRET=choose-a-long-random-string

# Recommended (Daily Brief / Vibe / Tier 1 use live market data without it the
# brief falls back to web-search-only and Tier 1 cannot run)
POLYGON_API_KEY=

# Optional
LOG_LEVEL=info
OUTPUT_DIR=/tmp
PORT=8080

# Email routing (defaults baked in; override if needed)
EMAIL_TO=steven12.reed@gmail.com
EMAIL_FROM=White80 <brief@white80.io>

# Used by scripts/cron-trigger.sh when the service is not reachable on localhost
# ROUTINE_URL=https://your-railway-service.up.railway.app
