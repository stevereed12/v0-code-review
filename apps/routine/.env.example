# ─── White80 Routine — Environment Variables ─────────────────────────────────
# Copy to .env and fill in values before running locally or deploying to Railway.

# LLM (Perplexity Agent API — routes to Grok, Sonar, Gemini, Claude per agent)
PERPLEXITY_API_KEY=

# Market data
POLYGON_API_KEY=

# Email delivery (Resend)
RESEND_API_KEY=
EMAIL_FROM=contact@white80.io
EMAIL_TO=steven12.reed@gmail.com

# Manual trigger auth — guards POST /run endpoint
# Generate with: openssl rand -hex 32
RUN_SECRET=

# Optional overrides
# LOG_LEVEL=info
# OUTPUT_DIR=/tmp
# ROUTINE_URL=https://your-railway-service.up.railway.app
